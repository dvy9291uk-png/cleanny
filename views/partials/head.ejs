<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= typeof title !== 'undefined' ? title : 'Cleanny | Clean Spaces, Brighter Tomorrows' %></title>
<meta name="description" content="<%= typeof desc !== 'undefined' ? desc : 'Cleanny — book vetted, insured cleaning professionals online in minutes. Domestic, end of tenancy, deep cleaning and more. Clean Spaces, Brighter Tomorrows.' %>">
<link rel="icon" href="/img/favicon.png" type="image/png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="bg-anim" aria-hidden="true">
  <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
  <i class="spark"><svg viewBox="0 0 24 24"><path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6z"/></svg></i>
  <i class="spark"><svg viewBox="0 0 24 24"><path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6z"/></svg></i>
  <i class="spark"><svg viewBox="0 0 24 24"><path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6z"/></svg></i>
  <i class="spark"><svg viewBox="0 0 24 24"><path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6z"/></svg></i>
</div>
<header class="site-header">
  <nav class="nav wrap">
    <a class="brand" href="/"><img src="/img/logo-light.png" alt="Cleanny — Clean Spaces, Brighter Tomorrows"></a>
    <button class="nav-toggle" aria-label="Menu" onclick="document.body.classList.toggle('nav-open')"><span></span><span></span><span></span></button>
    <div class="nav-links">
      <a href="/services" class="<%= page==='services'?'on':'' %>">Services</a>
      <a href="/faqs" class="<%= page==='faqs'?'on':'' %>">FAQs</a>
      <a href="/pro" class="<%= page==='pro'?'on':'' %>">For Professionals</a>
      <a href="/contact" class="<%= page==='contact'?'on':'' %>">Contact</a>
      <% if (user) { %>
        <a href="<%= user.role==='admin' ? '/admin' : '/account' %>" class="btn btn-ghost"><%= user.role==='admin' ? 'Dashboard' : 'My bookings' %></a>
        <form method="post" action="/signout" class="inline-form"><button class="linklike" type="submit">Sign out</button></form>
      <% } else { %>
        <a href="/signin" class="btn btn-ghost">Sign in</a>
        <a href="/services" class="btn btn-solid">Book a clean</a>
      <% } %>
    </div>
  </nav>
</header>
<main>
