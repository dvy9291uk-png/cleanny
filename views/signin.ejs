<%- include('partials/head', { title: 'Sign in | Cleanny' }) %>
<section class="section">
  <div class="wrap narrow">
    <form class="card book-form auth-form" method="post" action="/signin">
      <h1>Sign in</h1>
      <% if (typeof error !== 'undefined') { %><p class="form-error"><%= error %></p><% } %>
      <input type="hidden" name="next" value="<%= next %>">
      <label>Email<input name="email" type="email" required autocomplete="email"></label>
      <label>Password<input name="password" type="password" required autocomplete="current-password"></label>
      <button class="btn btn-solid btn-lg" type="submit">Sign in</button>
      <p class="small-note">New to Cleanny? <a href="/signup">Create an account</a></p>
    </form>
  </div>
</section>
<%- include('partials/foot') %>

